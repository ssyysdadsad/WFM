/* ===== 全局样式 — Figma 蓝白渐变风格 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: linear-gradient(160deg, #F6F8FA 0%, #E9F4FF 100%);
  color: #1A2E4A;
  font-size: 28rpx;
  min-height: 100vh;
}

/* ===== 通用布局 ===== */
.container { padding: 24rpx; }
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.gap-sm { gap: 12rpx; }
.gap-md { gap: 20rpx; }
.gap-lg { gap: 32rpx; }

/* ===== 卡片 ===== */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(40,149,255,0.08);
  border: 1rpx solid #DDE9FF;
  margin-bottom: 24rpx;
}
.card-purple {
  box-shadow: 0 4rpx 20rpx rgba(123,111,226,0.08);
  border-color: #E8E5FF;
}

/* ===== 渐变背景头部 ===== */
.header-gradient {
  background: linear-gradient(135deg, #2895FF 0%, #3EAAFF 50%, #62D9FF 100%);
  position: relative;
  overflow: hidden;
  color: #fff;
}
.header-gradient .deco-circle-1 {
  position: absolute; top: -80rpx; right: -80rpx;
  width: 320rpx; height: 320rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.header-gradient .deco-circle-2 {
  position: absolute; bottom: 0; left: 0;
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

/* ===== 蓝色渐变按钮 ===== */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(90deg, #2895FF 0%, #62D9FF 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(40,149,255,0.30);
  border: none;
}
.btn-primary::after { border: none; }
.btn-primary[disabled] { opacity: 0.5; }

.btn-outline {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #D96B5A;
  border: 2rpx solid #FFCFC9;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-outline::after { border: none; }

/* ===== 输入框 ===== */
.input-group {
  display: flex;
  align-items: center;
  background: #F6F8FA;
  border-radius: 24rpx;
  padding: 0 32rpx;
  height: 96rpx;
  border: 2rpx solid #DDE9FF;
  margin-bottom: 20rpx;
}
.input-group:focus-within,
.input-group.focus {
  border-color: #62D9FF;
}
.input-group .icon {
  width: 36rpx; height: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.input-group input {
  flex: 1;
  font-size: 28rpx;
  color: #1A2E4A;
}
.input-group .placeholder {
  color: #C0CFDD;
}

/* ===== Tag ===== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
}

/* ===== Section Title ===== */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 0 16rpx;
}
.section-title .bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
}
.section-title .bar-blue { background: #2895FF; }
.section-title .bar-purple { background: #7B6FE2; }
.section-title text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2E4A;
}

/* ===== 提示 ===== */
.alert-warning {
  background: #FFF8E1;
  color: #F57F17;
  border: 2rpx solid #FFE082;
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 26rpx;
  margin-bottom: 32rpx;
}
.alert-error {
  background: #FFF0EE;
  color: #D96B5A;
  border: 2rpx solid #FFD9D4;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}
.alert-success {
  background: #F0FFF4;
  color: #2E7D32;
  border: 2rpx solid #C8E6C9;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

/* ===== Info Row ===== */
.info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F5FA;
}
.info-row:last-child { border-bottom: none; }
.info-row .label {
  font-size: 24rpx; color: #A3B5C8;
  width: 136rpx; flex-shrink: 0;
}
.info-row .value {
  font-size: 26rpx; color: #1A2E4A;
  font-weight: 500; flex: 1;
}

/* ===== Loading ===== */
.loading-center {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
