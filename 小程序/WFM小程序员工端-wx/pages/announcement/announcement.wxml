<view class="ann-page">
  <!-- Detail view -->
  <view wx:if="{{selectedAnn}}" class="container">
    <view class="card" style="padding:0;">
      <view style="padding:24rpx 32rpx;border-bottom:1rpx solid #F0F5FA;">
        <view class="flex-row" style="margin-bottom:16rpx;">
          <view bindtap="closeDetail" style="color:#2895FF;font-size:26rpx;">← 返回列表</view>
        </view>
        <text style="display:block;font-size:28rpx;font-weight:600;color:#1A2E4A;">公告详情</text>
      </view>
      <view style="padding:32rpx;">
        <view class="flex-row gap-sm" style="margin-bottom:20rpx;">
          <text class="tag" style="background:{{selectedAnn.tagBg}};color:{{selectedAnn.tagColor}};">{{selectedAnn.type}}</text>
        </view>
        <text style="display:block;font-size:30rpx;font-weight:600;color:#1A2E4A;margin-bottom:12rpx;">{{selectedAnn.title}}</text>
        <text style="display:block;font-size:22rpx;color:#A3B5C8;margin-bottom:32rpx;">{{selectedAnn.date}} 发布</text>
        <text style="font-size:26rpx;color:#4A5E75;line-height:1.8;">{{selectedAnn.content}}</text>
      </view>
    </view>
  </view>

  <!-- List view -->
  <view wx:else>
    <view class="filter-bar">
      <text class="header-title">公告通知</text>
      <scroll-view scroll-x class="type-scroll">
        <view wx:for="{{types}}" wx:key="*this" class="type-btn {{selectedType === item ? 'active' : ''}}"
          bindtap="onTypeChange" data-type="{{item}}">{{item}}</view>
      </scroll-view>
    </view>

    <view class="container">
      <view wx:if="{{loading}}" class="loading-center"><text style="color:#2895FF;">加载中...</text></view>
      <view wx:elif="{{announcements.length === 0}}" class="empty-state">
        <text style="font-size:60rpx;">🔔</text>
        <text style="color:#A3B5C8;font-size:26rpx;margin-top:16rpx;">暂无公告</text>
      </view>
      <view wx:else>
        <view wx:for="{{announcements}}" wx:key="id" class="card ann-card" bindtap="openDetail" data-id="{{item.id}}">
          <view class="flex-row gap-md">
            <view class="ann-icon" style="background:{{item.tagBg}};">
              <text style="font-size:32rpx;">{{item.emoji}}</text>
            </view>
            <view class="flex-1" style="min-width:0;">
              <view class="flex-row" style="justify-content:space-between;margin-bottom:8rpx;">
                <text class="ann-title">{{item.title}}</text>
                <text style="font-size:24rpx;color:#C0CFDD;">▶</text>
              </view>
              <text class="ann-content">{{item.content}}</text>
              <view class="flex-row gap-sm" style="margin-top:12rpx;">
                <text class="tag" style="background:{{item.tagBg}};color:{{item.tagColor}};font-size:20rpx;">{{item.type}}</text>
                <text style="font-size:20rpx;color:#C0CFDD;">{{item.date}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
