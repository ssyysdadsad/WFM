.login-page { min-height: 100vh; display: flex; flex-direction: column; background: linear-gradient(160deg, #F6F8FA 0%, #E9F4FF 100%); }

.hero { padding: 112rpx 64rpx 96rpx; }
.hero-content { position: relative; z-index: 10; }
.logo-box {
  width: 112rpx; height: 112rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
}
.logo-icon { width: 56rpx; height: 56rpx; }
.hero-title { display: block; font-size: 48rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; letter-spacing: 2rpx; }
.hero-sub { display: block; font-size: 28rpx; color: rgba(255,255,255,0.7); }

.login-card {
  flex: 1;
  background: #fff;
  border-radius: 56rpx 56rpx 0 0;
  margin-top: -32rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow: 0 -8rpx 48rpx rgba(40,149,255,0.10);
}
.card-title { display: block; font-size: 36rpx; font-weight: 700; color: #1A2E4A; margin-bottom: 8rpx; }
.card-sub { display: block; font-size: 26rpx; color: #A3B5C8; margin-bottom: 48rpx; }

.eye-btn { padding: 16rpx; margin-left: 8rpx; }

.hint-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #C0CFDD;
  margin-top: 48rpx;
}
