.login-page { min-height: 100vh; display: flex; flex-direction: column; background: #F2F5F9; }

.hero { padding: 120rpx 64rpx 96rpx; }
.hero-content { position: relative; z-index: 10; }
.logo-box {
  width: 120rpx; height: 120rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 32rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  backdrop-filter: blur(12px);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}
.logo-icon { width: 56rpx; height: 56rpx; }
.hero-title { display: block; font-size: 52rpx; font-weight: 800; color: #fff; margin-bottom: 12rpx; letter-spacing: 3rpx; }
.hero-sub { display: block; font-size: 28rpx; color: rgba(255,255,255,0.65); letter-spacing: 1rpx; }

.login-card {
  flex: 1;
  background: rgba(255,255,255,0.95);
  border-radius: 56rpx 56rpx 0 0;
  margin-top: -32rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow: 0 -8rpx 48rpx rgba(30,111,217,0.08);
  backdrop-filter: blur(20px);
}
.card-title { display: block; font-size: 38rpx; font-weight: 800; color: #1A2233; margin-bottom: 8rpx; letter-spacing: 1rpx; }
.card-sub { display: block; font-size: 26rpx; color: #8899AA; margin-bottom: 48rpx; }

.eye-btn { padding: 16rpx; margin-left: 8rpx; }

.hint-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #B0BFCC;
  margin-top: 48rpx;
}
