/* ===== Apply Page — 现代磨砂设计 ===== */
.apply-page { min-height: 100vh; background: #F2F5F9; }

/* Tab bar */
.tab-bar { display: flex; background: rgba(255,255,255,0.92); border-bottom: 1rpx solid rgba(232,238,244,0.5); backdrop-filter: blur(20px); }
.tab { flex: 1; text-align: center; padding: 26rpx 0; font-size: 28rpx; color: #8899AA; font-weight: 500; position: relative; transition: color 0.2s; }
.tab.active { color: #1E6FD9; font-weight: 700; }
.tab.active::after { content: ''; position: absolute; bottom: 0; left: 30%; right: 30%; height: 5rpx; background: linear-gradient(90deg, #3B8BF2, #1E6FD9); border-radius: 3rpx; }

/* Tab badge */
.badge {
  position: absolute; top: 8rpx; right: 16rpx;
  min-width: 32rpx; height: 32rpx; line-height: 32rpx;
  font-size: 20rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #FF4D4F, #E8384F); border-radius: 16rpx;
  padding: 0 8rpx; text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(255,77,79,0.25);
}

/* Container */
.container { padding: 24rpx; }

/* Card */
.card { background: rgba(255,255,255,0.92); border-radius: 22rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); border: 1rpx solid rgba(255,255,255,0.6); backdrop-filter: blur(10px); }

/* Request list */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.request-card { padding: 24rpx; }
.req-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.tag { padding: 6rpx 18rpx; border-radius: 10rpx; font-size: 22rpx; font-weight: 600; }
.req-type-tag { font-size: 20rpx; color: #5A7A9A; background: rgba(235,244,255,0.8); padding: 4rpx 14rpx; border-radius: 8rpx; }
.req-time { font-size: 22rpx; color: #8899AA; margin-left: auto; }
.req-body {}
.req-label { display: block; font-size: 26rpx; color: #1A2233; margin-bottom: 8rpx; }
.req-reason { display: block; font-size: 24rpx; color: #8899AA; margin-top: 8rpx; }

/* Applicant card */
.applicant-card {
  background: rgba(255,255,255,0.92);
  border-radius: 22rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  border-left: 6rpx solid #3B8BF2;
  backdrop-filter: blur(10px);
}
.applicant-line { font-size: 26rpx; color: #5A7A9A; display: block; }
.applicant-bold { font-weight: 700; color: #1A2233; }
.applicant-hint { font-size: 22rpx; color: #8899AA; display: block; margin-top: 8rpx; }

/* Request type tabs */
.type-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.type-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid rgba(232,238,244,0.6);
  color: #5A7A9A;
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(6px);
  transition: all 0.2s;
}
.type-tab.active-outline {
  border-color: #3B8BF2;
  color: #1E6FD9;
  font-weight: 600;
}
.type-tab.active-fill {
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  border-color: transparent;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(59,139,242,0.2);
}

/* Form layout */
.form-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.form-col { flex: 1; }

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1A2233;
  margin-bottom: 12rpx;
  margin-top: 16rpx;
}

/* Input box */
.input-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(246,248,250,0.8);
  border: 2rpx solid rgba(232,238,244,0.5);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  min-height: 44rpx;
  margin-bottom: 8rpx;
  transition: border-color 0.2s, background 0.2s;
}
.input-value { font-size: 28rpx; color: #1A2233; }
.input-placeholder { font-size: 26rpx; color: #B0BFCC; }
.input-icon { font-size: 28rpx; }

/* Textarea */
.textarea-box {
  background: rgba(246,248,250,0.8);
  border: 2rpx solid rgba(232,238,244,0.5);
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: border-color 0.2s;
}
.textarea-box textarea {
  width: 100%;
  font-size: 28rpx;
  color: #1A2233;
  min-height: 140rpx;
}

/* Swap arrow */
.swap-arrow {
  display: flex;
  justify-content: center;
  padding: 12rpx 0;
}
.swap-icon {
  font-size: 40rpx;
  color: #3B8BF2;
  font-weight: 700;
}

/* Submit button */
.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 24rpx 0;
  border-radius: 22rpx;
  border: none;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(30,111,217,0.2);
  letter-spacing: 1rpx;
}
.submit-btn[disabled] {
  opacity: 0.5;
}
.submit-btn.btn-disabled {
  background: #C0CCDA;
  box-shadow: none;
}

/* Alerts */
.alert-success {
  background: rgba(228,250,245,0.9);
  color: #12B8A0;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(18,184,160,0.15);
}
.alert-error {
  background: rgba(255,240,238,0.9);
  color: #D96B5A;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(217,107,90,0.15);
}

/* Loading */
.loading-center {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

/* Error states */
.input-box.input-error {
  border-color: #D96B5A;
  background: rgba(255,245,244,0.8);
}
.field-error {
  display: block;
  font-size: 22rpx;
  color: #D96B5A;
  margin-top: 4rpx;
  font-weight: 500;
}

/* ===== Urgent Shift Styles ===== */
.urgent-section { margin-bottom: 24rpx; }

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2233;
  margin-bottom: 16rpx;
}

/* Urgent card */
.urgent-card {
  border-left: 6rpx solid #FB923C;
  padding: 24rpx;
}
.urgent-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.urgent-badge {
  background: linear-gradient(135deg, #FB923C, #F97316);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(249,115,22,0.2);
}
.urgent-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A2233;
  flex: 1;
}
.urgent-body { margin-bottom: 16rpx; }
.urgent-info-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.urgent-info-icon { font-size: 24rpx; }
.urgent-info-text { font-size: 26rpx; color: #5A7A9A; }
.urgent-desc {
  background: rgba(255,248,240,0.8);
  border-radius: 14rpx;
  padding: 16rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8B6914;
}

/* Urgent action buttons */
.urgent-actions {
  display: flex;
  justify-content: flex-end;
}
.urgent-btn {
  background: linear-gradient(135deg, #FB923C, #F97316);
  color: #fff;
  padding: 14rpx 40rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.2);
}
.urgent-btn-disabled {
  background: rgba(232,238,244,0.8);
  color: #8899AA;
  padding: 14rpx 40rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.urgent-btn-conflict {
  background: rgba(255,240,238,0.8);
  color: #D96B5A;
  padding: 14rpx 40rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.urgent-btn-warn {
  background: linear-gradient(135deg, #FFA726, #F57C00);
  color: #fff;
  padding: 14rpx 40rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(255,152,0,0.2);
}

/* Signup card */
.urgent-signup-card {
  border-left: 6rpx solid #3B8BF2;
}
.urgent-title-text {
  font-weight: 700;
  color: #1A2233;
  font-size: 28rpx;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  backdrop-filter: blur(6px);
}
.modal-content {
  width: 600rpx;
  background: rgba(255,255,255,0.96);
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.12);
  backdrop-filter: blur(20px);
}
.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1A2233;
  margin-bottom: 12rpx;
}
.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #5A7A9A;
}
.modal-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.modal-btn-cancel {
  flex: 1;
  background: rgba(242,245,249,0.8);
  color: #5A7A9A;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 0;
  border-radius: 18rpx;
  border: none;
}
.modal-btn-confirm {
  flex: 1;
  background: linear-gradient(135deg, #FB923C, #F97316);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 18rpx 0;
  border-radius: 18rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.2);
}
.modal-btn-confirm[disabled] { opacity: 0.5; }

/* Labor rule warnings */
.labor-warnings {
  background: rgba(255,248,240,0.85);
  border: 2rpx solid rgba(255,224,178,0.5);
  border-radius: 14rpx;
  padding: 16rpx;
  margin-top: 12rpx;
}
.labor-warning-item {
  font-size: 24rpx;
  color: #E65100;
  margin-bottom: 6rpx;
  line-height: 1.4;
}
.labor-warning-item:last-child {
  margin-bottom: 0;
}

/* Peer confirm actions */
.peer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  justify-content: flex-end;
}
.peer-btn {
  padding: 14rpx 40rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  line-height: 1;
}
.peer-approve {
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(30,111,217,0.2);
}
.peer-reject {
  background: rgba(255,240,238,0.8);
  color: #D96B5A;
}

/* Empty hint */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(246,248,250,0.6);
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #8899AA;
}

/* Field hint */
.field-hint {
  display: block;
  font-size: 22rpx;
  color: #8899AA;
  margin-top: 4rpx;
  margin-bottom: 8rpx;
}

/* Peer confirm - shift info block */
.peer-shift-info {
  background: rgba(246,249,255,0.8);
  border-left: 4rpx solid #3B8BF2;
  border-radius: 0 14rpx 14rpx 0;
  padding: 10rpx 16rpx;
  margin: 8rpx 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
