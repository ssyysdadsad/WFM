/* ===== 首页样式 — 现代磨砂设计 ===== */
.home-page { position: relative; min-height: 100vh; }

/* --- Header --- */
.header { padding: 24rpx 32rpx 0; padding-bottom: 0; }
.header-top { justify-content: space-between; }
.brand-icon {
  width: 72rpx; height: 72rpx;
  background: rgba(255,255,255,0.15); border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 22rpx; font-weight: 800;
  border: 1rpx solid rgba(255,255,255,0.2);
  letter-spacing: 1rpx;
  backdrop-filter: blur(8px);
}
.brand-name { color: #fff; font-size: 34rpx; font-weight: 800; letter-spacing: 2rpx; }
.pro-tag {
  background: rgba(255,255,255,0.15); border-radius: 8rpx;
  padding: 4rpx 14rpx; font-size: 18rpx; color: rgba(255,255,255,0.9);
  font-weight: 600; border: 1rpx solid rgba(255,255,255,0.15);
  backdrop-filter: blur(6px);
}
.user-name { color: rgba(255,255,255,0.9); font-size: 26rpx; font-weight: 500; }
.avatar {
  width: 68rpx; height: 68rpx;
  background: rgba(255,255,255,0.2); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 24rpx; font-weight: 700;
  border: 2rpx solid rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
}

/* --- Header date row --- */
.header-date-row {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 24rpx; padding: 0 4rpx;
}
.header-date { font-size: 30rpx; font-weight: 700; color: #fff; }
.header-shift-tag {
  background: rgba(255,255,255,0.18); border-radius: 16rpx;
  padding: 8rpx 24rpx; font-size: 24rpx; color: #fff;
  font-weight: 600; border: 1rpx solid rgba(255,255,255,0.12);
  backdrop-filter: blur(6px);
}
.rest-tag { background: rgba(255,255,255,0.10); }

/* --- Mini calendar --- */
.mini-cal {
  margin-top: 20rpx; padding: 16rpx 0;
}
.mini-cal-header {
  display: flex;
}
.mini-cal-weekday {
  flex: 1; text-align: center; font-size: 22rpx;
  color: rgba(255,255,255,0.55); font-weight: 500;
  padding-bottom: 12rpx;
}
.mini-cal-body { display: flex; flex-wrap: wrap; }
.mini-cal-cell {
  width: 14.28%; text-align: center; padding: 6rpx 0 4rpx;
  font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 500;
  display: flex; flex-direction: column; align-items: center;
  gap: 0;
}
.mini-cal-day {
  font-size: 22rpx; line-height: 1.2;
}
.mini-cal-code {
  font-size: 16rpx; font-weight: 600; line-height: 1.1;
  opacity: 0.9;
}
.mini-cal-time {
  font-size: 14rpx; font-weight: 400; line-height: 1.1;
  opacity: 0.7;
}
.mini-cal-cell.is-today {
  position: relative;
}
.mini-cal-cell.is-today .mini-cal-day {
  display: inline-flex; align-items: center; justify-content: center;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #fff; color: #1E6FD9; font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.mini-cal-cell.empty { visibility: hidden; }

/* --- Hours bar --- */
.hours-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 8rpx; padding: 16rpx 4rpx 24rpx;
}
.hours-bar-text {
  font-size: 22rpx; color: rgba(255,255,255,0.7); font-weight: 500;
}
.hours-bar-right { display: flex; align-items: center; }
.hours-bar-badge {
  background: rgba(255,255,255,0.15); border-radius: 20rpx;
  padding: 8rpx 20rpx; font-size: 22rpx; color: #fff;
  font-weight: 500; border: 1rpx solid rgba(255,255,255,0.1);
  backdrop-filter: blur(6px);
}

/* --- Content --- */
.content { padding: 24rpx 24rpx 0; margin-top: -8rpx; }

/* --- Today card --- */
.today-card { padding: 28rpx 32rpx; }
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.section-header-standalone {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx; margin-top: 8rpx; padding: 0 4rpx;
}
.section-title-text {
  font-size: 32rpx; font-weight: 700; color: #1A2233;
}
.shift-tag {
  display: inline-flex; align-items: center; padding: 8rpx 20rpx;
  border-radius: 14rpx; font-size: 24rpx; font-weight: 600;
}
.shift-tag.small { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 10rpx; }
.rest-shift-tag { background: #F0F2F5 !important; color: #8899AA !important; }
.today-info {
  display: flex; align-items: center; padding: 0 4rpx;
}
.today-info-left { flex: 1; }
.info-line {
  display: flex; align-items: center; padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(240,242,245,0.8);
}
.info-line:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #8899AA; width: 100rpx; flex-shrink: 0; }
.info-value { font-size: 26rpx; color: #1A2233; font-weight: 500; flex: 1; }
.today-shift-badge {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 120rpx; height: 120rpx; border-radius: 24rpx;
  margin-left: 24rpx; flex-shrink: 0;
}
.today-shift-badge-code {
  font-size: 40rpx; font-weight: 800; line-height: 1.1;
}
.today-shift-badge-time {
  font-size: 20rpx; font-weight: 500; margin-top: 4rpx; opacity: 0.8;
}
.today-shift-badge.rest-badge {
  background: #F0F2F5; color: #8899AA; border: 2rpx solid rgba(136,153,170,0.15);
}
.rest-text { font-size: 28rpx; color: #8899AA; font-weight: 500; }
.detail-btn {
  display: flex; align-items: center; justify-content: center;
  margin-top: 20rpx; padding: 18rpx;
  background: linear-gradient(135deg, rgba(59,139,242,0.08) 0%, rgba(91,168,255,0.08) 100%);
  border-radius: 16rpx; border: 1rpx solid rgba(59,139,242,0.12);
}
.detail-btn text {
  font-size: 26rpx; color: #3B8BF2; font-weight: 600;
}

/* --- Future grid --- */
.future-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-bottom: 24rpx;
}
.future-card {
  width: calc(50% - 8rpx);
  background: rgba(255,255,255,0.92); border-radius: 22rpx;
  padding: 24rpx; box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(10px);
}
.future-date-text {
  font-size: 28rpx; font-weight: 700; color: #1A2233;
  display: block; margin-bottom: 12rpx;
}
.future-project {
  display: block; font-size: 22rpx; color: #8899AA;
  margin-top: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* --- Action grid --- */
.action-grid {
  display: flex; gap: 14rpx;
  margin-top: 8rpx; margin-bottom: 40rpx;
}
.action-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 24rpx 8rpx; border-radius: 22rpx;
  min-height: 120rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  overflow: hidden;
}
.action-btn::after {
  content: '';
  position: absolute; top: -30%; right: -20%;
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.action-icon { font-size: 40rpx; margin-bottom: 10rpx; position: relative; z-index: 1; }
.action-label { font-size: 22rpx; font-weight: 600; color: #fff; position: relative; z-index: 1; letter-spacing: 1rpx; }
.action-blue { background: linear-gradient(145deg, #3B8BF2, #1E6FD9); }
.action-green { background: linear-gradient(145deg, #34D399, #10B981); }
.action-orange { background: linear-gradient(145deg, #FB923C, #F97316); }
.action-purple { background: linear-gradient(145deg, #A78BFA, #8B5CF6); }

/* --- Loading --- */
.loading-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.75); display: flex;
  align-items: center; justify-content: center; z-index: 999;
  backdrop-filter: blur(6px);
}
.loading-spinner {
  width: 64rpx; height: 64rpx; border: 6rpx solid rgba(59,139,242,0.15);
  border-top-color: #3B8BF2; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* --- Urgent shift banner --- */
.urgent-banner {
  background: linear-gradient(145deg, rgba(255,243,224,0.95) 0%, rgba(255,224,178,0.95) 100%);
  border-radius: 22rpx; padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(255,183,77,0.35);
  box-shadow: 0 4rpx 16rpx rgba(255,152,0,0.1);
  backdrop-filter: blur(10px);
}
.urgent-banner-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx;
}
.urgent-banner-left {
  display: flex; align-items: center; gap: 8rpx;
}
.urgent-icon {
  font-size: 32rpx;
  animation: urgentPulse 1.5s ease-in-out infinite;
}
@keyframes urgentPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.15); }
}
.urgent-banner-title {
  font-size: 30rpx; font-weight: 700; color: #E65100;
}
.urgent-badge {
  background: linear-gradient(135deg, #FF5722, #E64A19); color: #fff; border-radius: 50%;
  width: 40rpx; height: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(255,87,34,0.25);
}
.urgent-banner-link {
  font-size: 24rpx; color: #E65100; font-weight: 500;
}
.urgent-list { display: flex; flex-direction: column; gap: 12rpx; }
.urgent-item {
  background: rgba(255,255,255,0.8); border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255,183,77,0.2);
  backdrop-filter: blur(6px);
}
.urgent-item-top {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 8rpx;
}
.urgent-item-title {
  font-size: 28rpx; font-weight: 700; color: #1A2233;
  flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.urgent-status {
  font-size: 22rpx; font-weight: 600; padding: 4rpx 16rpx;
  border-radius: 10rpx; flex-shrink: 0; margin-left: 12rpx;
}
.urgent-status.open { background: rgba(232,245,233,0.8); color: #2E7D32; }
.urgent-status.pending { background: rgba(227,242,253,0.8); color: #1565C0; }
.urgent-status.approved { background: rgba(243,229,245,0.8); color: #7B1FA2; }
.urgent-status.rejected { background: rgba(255,235,238,0.8); color: #C62828; }
.urgent-item-info {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-bottom: 8rpx;
}
.urgent-info-text { font-size: 24rpx; color: #666; }
.urgent-item-bottom {
  display: flex; justify-content: space-between; align-items: center;
}
.urgent-need { font-size: 24rpx; color: #E65100; font-weight: 600; }
.urgent-deadline { font-size: 22rpx; color: #FF5722; font-weight: 500; }
