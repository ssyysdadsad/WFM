/* ===== 首页样式 — 参考 Figma CM WFM PRO 设计 ===== */
.home-page { position: relative; min-height: 100vh; }

/* --- Header --- */
.header { padding: 24rpx 32rpx 0; padding-bottom: 0; }
.header-top { justify-content: space-between; }
.brand-icon {
  width: 72rpx; height: 72rpx;
  background: rgba(255,255,255,0.2); border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 22rpx; font-weight: 800;
  border: 1rpx solid rgba(255,255,255,0.15);
  letter-spacing: 1rpx;
}
.brand-name { color: #fff; font-size: 34rpx; font-weight: 800; }
.pro-tag {
  background: rgba(255,255,255,0.2); border-radius: 8rpx;
  padding: 4rpx 12rpx; font-size: 18rpx; color: #fff;
  font-weight: 600; border: 1rpx solid rgba(255,255,255,0.2);
}
.user-name { color: rgba(255,255,255,0.9); font-size: 26rpx; font-weight: 500; }
.avatar {
  width: 64rpx; height: 64rpx;
  background: rgba(255,255,255,0.25); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 24rpx; font-weight: 700;
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* --- Header date row --- */
.header-date-row {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 24rpx; padding: 0 4rpx;
}
.header-date { font-size: 30rpx; font-weight: 700; color: #fff; }
.header-shift-tag {
  background: rgba(255,255,255,0.2); border-radius: 16rpx;
  padding: 8rpx 24rpx; font-size: 24rpx; color: #fff;
  font-weight: 600; border: 1rpx solid rgba(255,255,255,0.15);
}
.rest-tag { background: rgba(255,255,255,0.12); }

/* --- Mini calendar --- */
.mini-cal {
  margin-top: 20rpx; padding: 16rpx 0;
}
.mini-cal-header {
  display: flex;
}
.mini-cal-weekday {
  flex: 1; text-align: center; font-size: 22rpx;
  color: rgba(255,255,255,0.6); font-weight: 500;
  padding-bottom: 12rpx;
}
.mini-cal-body { display: flex; flex-wrap: wrap; }
.mini-cal-cell {
  width: 14.28%; text-align: center; padding: 8rpx 0;
  font-size: 24rpx; color: rgba(255,255,255,0.85); font-weight: 500;
}
.mini-cal-cell.is-today {
  position: relative;
}
.mini-cal-cell.is-today text {
  display: inline-flex; align-items: center; justify-content: center;
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: #fff; color: #2895FF; font-weight: 800;
}
.mini-cal-cell.empty { visibility: hidden; }

/* --- Hours bar --- */
.hours-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 8rpx; padding: 16rpx 4rpx 24rpx;
}
.hours-bar-text {
  font-size: 22rpx; color: rgba(255,255,255,0.75); font-weight: 500;
}
.hours-bar-right { display: flex; align-items: center; }
.hours-bar-badge {
  background: rgba(255,255,255,0.18); border-radius: 20rpx;
  padding: 8rpx 20rpx; font-size: 22rpx; color: #fff;
  font-weight: 500; border: 1rpx solid rgba(255,255,255,0.1);
}

/* --- Content --- */
.content { padding: 24rpx 24rpx 0; margin-top: -8rpx; }

/* --- Today card --- */
.today-card { padding: 28rpx 32rpx; }
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.section-header-standalone {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx; margin-top: 8rpx; padding: 0 4rpx;
}
.section-title-text {
  font-size: 32rpx; font-weight: 700; color: #1A2E4A;
}
.shift-tag {
  display: inline-flex; align-items: center; padding: 8rpx 20rpx;
  border-radius: 12rpx; font-size: 24rpx; font-weight: 600;
}
.shift-tag.small { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 10rpx; }
.rest-shift-tag { background: #F5F5F5 !important; color: #9E9E9E !important; }
.today-info { padding: 0 4rpx; }
.info-line {
  display: flex; align-items: center; padding: 10rpx 0;
  border-bottom: 1rpx solid #F5F8FB;
}
.info-line:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #A3B5C8; width: 100rpx; flex-shrink: 0; }
.info-value { font-size: 26rpx; color: #1A2E4A; font-weight: 500; flex: 1; }
.today-rest {
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx; background: #F8FAFC; border-radius: 16rpx;
}
.rest-text { font-size: 28rpx; color: #A3B5C8; font-weight: 500; }
.detail-btn {
  display: flex; align-items: center; justify-content: center;
  margin-top: 20rpx; padding: 18rpx;
  background: linear-gradient(90deg, #EBF4FF 0%, #F0F8FF 100%);
  border-radius: 16rpx; border: 1rpx solid #D6E8FF;
}
.detail-btn text {
  font-size: 26rpx; color: #2895FF; font-weight: 600;
}

/* --- Future grid --- */
.future-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin-bottom: 24rpx;
}
.future-card {
  width: calc(50% - 8rpx);
  background: #fff; border-radius: 20rpx;
  padding: 24rpx; box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(40,149,255,0.06);
  border: 1rpx solid #E8F0FE;
}
.future-date-text {
  font-size: 28rpx; font-weight: 700; color: #1A2E4A;
  display: block; margin-bottom: 12rpx;
}
.future-project {
  display: block; font-size: 22rpx; color: #A3B5C8;
  margin-top: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* --- Action grid --- */
.action-grid {
  display: flex; gap: 12rpx;
  margin-top: 8rpx; margin-bottom: 40rpx;
}
.action-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 24rpx 8rpx; border-radius: 20rpx;
  min-height: 120rpx;
}
.action-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.action-label { font-size: 22rpx; font-weight: 600; color: #fff; }
.action-blue { background: linear-gradient(135deg, #2895FF, #62BFFF); }
.action-green { background: linear-gradient(135deg, #34C759, #5FE089); }
.action-orange { background: linear-gradient(135deg, #FF9500, #FFB340); }
.action-purple { background: linear-gradient(135deg, #AF52DE, #C77DEB); }

/* --- Loading --- */
.loading-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.7); display: flex;
  align-items: center; justify-content: center; z-index: 999;
}
.loading-spinner {
  width: 60rpx; height: 60rpx; border: 6rpx solid #E0E0E0;
  border-top-color: #2895FF; border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
