<view class="pwd-page">
  <view class="hero header-gradient" style="padding: 96rpx 48rpx 80rpx;">
    <view class="deco-circle-1"></view>
    <view class="deco-circle-2"></view>
    <view class="hero-content flex-row gap-md">
      <view class="shield-box">
        <image src="/assets/icon-shield.png" mode="aspectFit" style="width:48rpx;height:48rpx;" />
      </view>
      <view>
        <text class="pwd-title">修改密码</text>
        <text wx:if="{{isFirst}}" class="pwd-sub">首次登录，请先修改初始密码</text>
      </view>
    </view>
  </view>

  <view class="form-card">
    <view wx:if="{{isFirst}}" class="alert-warning">
      ⚠ 为确保账号安全，首次登录必须修改初始密码。修改成功后需重新登录。
    </view>

    <view wx:if="{{error}}" class="alert-error">{{error}}</view>

    <!-- New password -->
    <text class="field-label">新密码</text>
    <view class="input-group">
      <image src="/assets/icon-lock.png" class="icon" mode="aspectFit" />
      <input password="{{!showNew}}" placeholder="请输入新密码" placeholder-class="placeholder"
        value="{{newPwd}}" bindinput="onNewInput" />
      <view bindtap="toggleNew" style="padding:16rpx;">
        <image src="{{showNew ? '/assets/icon-eye.png' : '/assets/icon-eye-off.png'}}" class="icon" mode="aspectFit" />
      </view>
    </view>

    <!-- Confirm password -->
    <text class="field-label">确认新密码</text>
    <view class="input-group">
      <image src="/assets/icon-lock.png" class="icon" mode="aspectFit" />
      <input password="{{!showConfirm}}" placeholder="再次输入新密码" placeholder-class="placeholder"
        value="{{confirmPwd}}" bindinput="onConfirmInput" bindconfirm="handleSubmit" />
      <view bindtap="toggleConfirm" style="padding:16rpx;">
        <image src="{{showConfirm ? '/assets/icon-eye.png' : '/assets/icon-eye-off.png'}}" class="icon" mode="aspectFit" />
      </view>
    </view>

    <!-- Rules -->
    <view class="rules-box">
      <text class="rules-title">密码要求：</text>
      <view class="rule-item">
        <text class="rule-icon {{hasMinLen ? 'ok' : ''}}">✓</text>
        <text class="rule-text {{hasMinLen ? 'ok' : ''}}">至少 8 位字符</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon {{hasLetter ? 'ok' : ''}}">✓</text>
        <text class="rule-text {{hasLetter ? 'ok' : ''}}">包含字母</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon {{hasNumber ? 'ok' : ''}}">✓</text>
        <text class="rule-text {{hasNumber ? 'ok' : ''}}">包含数字</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon {{pwdMatch ? 'ok' : ''}}">✓</text>
        <text class="rule-text {{pwdMatch ? 'ok' : ''}}">两次密码一致</text>
      </view>
    </view>

    <button class="btn-primary" bindtap="handleSubmit" disabled="{{loading || !isValid}}"
      style="{{isValid ? '' : 'background:#CBD5E1;box-shadow:none;'}}">
      <text wx:if="{{loading}}">修改中...</text>
      <text wx:else>确认修改</text>
    </button>

    <text class="hint">修改成功后将自动退出，请使用新密码重新登录</text>
  </view>
</view>
