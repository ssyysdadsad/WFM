.pwd-page { min-height: 100vh; display: flex; flex-direction: column; background: #F2F5F9; }
.shield-box { width: 100rpx; height: 100rpx; background: rgba(255,255,255,0.15); border-radius: 28rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,0.2); backdrop-filter: blur(8px); }
.pwd-title { display: block; font-size: 42rpx; font-weight: 800; color: #fff; letter-spacing: 2rpx; }
.pwd-sub { display: block; font-size: 26rpx; color: rgba(255,255,255,0.75); margin-top: 6rpx; }
.form-card { flex: 1; background: rgba(255,255,255,0.95); border-radius: 56rpx 56rpx 0 0; margin-top: -32rpx; padding: 56rpx 48rpx 48rpx; box-shadow: 0 -8rpx 48rpx rgba(30,111,217,0.08); backdrop-filter: blur(20px); }
.field-label { display: block; font-size: 26rpx; font-weight: 600; color: #1A2233; margin-bottom: 16rpx; }
.rules-box { background: rgba(242,245,249,0.6); border-radius: 24rpx; padding: 32rpx; margin-bottom: 32rpx; }
.rules-title { display: block; font-size: 24rpx; font-weight: 500; color: #64748B; margin-bottom: 12rpx; }
.rule-item { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.rule-icon { font-size: 24rpx; color: #CBD5E1; }
.rule-icon.ok { color: #10B981; }
.rule-text { font-size: 24rpx; color: #94A3B8; }
.rule-text.ok { color: #10B981; }
.hint { display: block; text-align: center; font-size: 22rpx; color: #94A3B8; margin-top: 24rpx; }
