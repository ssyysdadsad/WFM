.pwd-page { min-height: 100vh; display: flex; flex-direction: column; background: linear-gradient(160deg, #F6F8FA 0%, #E9F4FF 100%); }
.shield-box { width: 96rpx; height: 96rpx; background: rgba(255,255,255,0.2); border-radius: 28rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,0.2); }
.pwd-title { display: block; font-size: 40rpx; font-weight: 700; color: #fff; }
.pwd-sub { display: block; font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }
.form-card { flex: 1; background: #fff; border-radius: 56rpx 56rpx 0 0; margin-top: -32rpx; padding: 56rpx 48rpx 48rpx; box-shadow: 0 -8rpx 48rpx rgba(40,149,255,0.10); }
.field-label { display: block; font-size: 26rpx; font-weight: 500; color: #1A2E4A; margin-bottom: 16rpx; }
.rules-box { background: #F8FAFC; border-radius: 24rpx; padding: 32rpx; margin-bottom: 32rpx; }
.rules-title { display: block; font-size: 24rpx; font-weight: 500; color: #64748B; margin-bottom: 12rpx; }
.rule-item { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.rule-icon { font-size: 24rpx; color: #CBD5E1; }
.rule-icon.ok { color: #2E7D32; }
.rule-text { font-size: 24rpx; color: #94A3B8; }
.rule-text.ok { color: #2E7D32; }
.hint { display: block; text-align: center; font-size: 22rpx; color: #94A3B8; margin-top: 24rpx; }
