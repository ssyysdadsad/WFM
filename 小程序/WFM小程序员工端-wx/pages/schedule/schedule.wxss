/* ===== Schedule Page — Figma Pro Design ===== */
.schedule-page {
  padding-bottom: 40rpx;
  background: #F0F4F8;
  min-height: 100vh;
}

/* --- Page Header --- */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A2E4A;
}
.export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border: 2rpx solid #2895FF;
  border-radius: 32rpx;
  background: #fff;
}
.export-icon {
  font-size: 26rpx;
  color: #2895FF;
}
.export-text {
  font-size: 24rpx;
  color: #2895FF;
  font-weight: 500;
}

/* --- Employee Card --- */
.emp-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F5FA;
}
.emp-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4DA0FF, #2178D9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.emp-info {
  display: flex;
  flex-direction: column;
}
.emp-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2E4A;
}
.emp-dept {
  font-size: 22rpx;
  color: #A3B5C8;
  margin-top: 4rpx;
}

/* --- Stats Row --- */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #fff;
}
.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}
.stat-blue {
  background: linear-gradient(135deg, #EBF4FF 0%, #D8EAFF 100%);
}
.stat-green {
  background: linear-gradient(135deg, #E6FAF0 0%, #C8F5DF 100%);
}
.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.stat-icon-blue {
  background: #2895FF;
  color: #fff;
}
.stat-icon-green {
  background: #21B573;
  color: #fff;
}
.stat-body {
  display: flex;
  flex-direction: column;
}
.stat-label {
  font-size: 22rpx;
  color: #5A7A9A;
  font-weight: 500;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A2E4A;
  margin-top: 2rpx;
}
.stat-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #5A7A9A;
  margin-left: 4rpx;
}

/* --- View Tabs --- */
.view-tabs {
  display: flex;
  margin: 16rpx 24rpx 0;
  background: #E8EEF4;
  border-radius: 16rpx;
  padding: 4rpx;
}
.view-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #5A7A9A;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.view-tab.active {
  background: #fff;
  color: #1A2E4A;
  font-weight: 600;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
}

/* --- Search Section --- */
.search-section {
  padding: 16rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.filter-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #E8EEF4;
  color: #5A7A9A;
}
.filter-tag.active {
  background: #2895FF;
  color: #fff;
}
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F6F8FA;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid #E8EEF4;
}
.search-icon {
  font-size: 26rpx;
  opacity: 0.5;
}
.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #1A2E4A;
}

/* --- Month Bar --- */
.month-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx 12rpx;
  gap: 48rpx;
}
.month-nav {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E8EEF4;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-arrow {
  font-size: 32rpx;
  color: #2895FF;
  font-weight: 700;
  line-height: 1;
}
.month-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A2E4A;
}

/* --- Calendar Wrap --- */
.calendar-wrap {
  margin: 0 24rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 8rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* --- Weekday row --- */
.weekday-row {
  display: flex;
  padding: 8rpx 0 12rpx;
  border-bottom: 1rpx solid #F0F5FA;
}
.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #A3B5C8;
  font-weight: 500;
}

/* --- Calendar grid --- */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 0;
}
.day-cell {
  width: 14.28%;
  padding: 14rpx 0 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  border-radius: 12rpx;
  box-sizing: border-box;
  position: relative;
}
.day-cell.empty {
  visibility: hidden;
}
.day-cell.selected {
  background: #EBF4FF;
}
.day-cell.today {
  position: relative;
}
.day-cell.today .day-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #2895FF;
  color: #fff;
  font-weight: 700;
}
.today-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2895FF;
  margin-top: 2rpx;
}
.day-num {
  font-size: 28rpx;
  color: #1A2E4A;
  font-weight: 500;
  min-height: 52rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.day-code {
  font-size: 20rpx;
  font-weight: 600;
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

/* --- Detail section --- */
.detail-section {
  padding: 0 24rpx;
}
.detail-date-header {
  margin-bottom: 16rpx;
}
.detail-date-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A2E4A;
}
.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.detail-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.detail-shift-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.detail-shift-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2E4A;
}
.detail-shift-time {
  font-size: 24rpx;
  color: #A3B5C8;
  margin-top: 4rpx;
}
.detail-hours {
  background: #EBF4FF;
  border-radius: 16rpx;
  padding: 10rpx 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2895FF;
  flex-shrink: 0;
}

/* --- Rest card --- */
.rest-card {}
.rest-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
}
.rest-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #A3B5C8;
}
.rest-sub {
  font-size: 24rpx;
  color: #C8D5E0;
}

/* --- Legend --- */
.legend-section {
  padding: 24rpx;
  margin-top: 8rpx;
}
.section-header-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
}
.bar-blue {
  background: #2895FF;
}
.legend-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2E4A;
}
.legend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.legend-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
.legend-chip-code {
  font-size: 22rpx;
  font-weight: 700;
}
.legend-chip-name {
  font-size: 20rpx;
  font-weight: 500;
}

/* ========== WEEK VIEW ========== */
.week-nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  gap: 40rpx;
}
.week-row {
  display: flex;
  margin: 0 24rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.week-day-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 0;
  border-radius: 16rpx;
}
.week-day-cell.today {
  background: #EBF4FF;
}
.week-day-cell.selected {
  background: #2895FF;
}
.week-day-cell.selected .week-day-label,
.week-day-cell.selected .week-day-num {
  color: #fff;
}
.week-day-label {
  font-size: 22rpx;
  color: #A3B5C8;
  font-weight: 500;
}
.week-day-num {
  font-size: 30rpx;
  color: #1A2E4A;
  font-weight: 600;
}
.week-day-code {
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 2rpx;
}
.rest-code {
  color: #9E9E9E;
  background: #F5F5F5;
}

/* Week detail list */
.week-detail-list {
  padding: 0 24rpx;
}
.week-detail-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.03);
}
.week-detail-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  flex-shrink: 0;
}
.week-detail-d {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A2E4A;
}
.week-detail-w {
  font-size: 20rpx;
  color: #A3B5C8;
}
.week-detail-shift {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 20rpx;
}
.week-detail-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.week-detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.week-detail-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A2E4A;
}
.week-detail-time {
  font-size: 22rpx;
  color: #A3B5C8;
  margin-top: 2rpx;
}
.week-detail-hours {
  font-size: 26rpx;
  font-weight: 700;
  color: #2895FF;
  flex-shrink: 0;
}
.rest-shift {
  flex: 1;
  margin-left: 20rpx;
}
.week-rest-text {
  font-size: 24rpx;
  color: #A3B5C8;
}

/* ========== DAY VIEW ========== */
.day-nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  gap: 40rpx;
}
.day-detail-wrap {
  padding: 0 24rpx;
}
.day-detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.day-detail-badge {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}
.day-detail-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}
.day-detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A2E4A;
  margin-bottom: 8rpx;
}
.day-detail-time {
  font-size: 26rpx;
  color: #5A7A9A;
  margin-bottom: 24rpx;
}
.day-detail-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #F6F8FA;
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  width: 100%;
  box-sizing: border-box;
}
.day-detail-hours-label {
  font-size: 24rpx;
  color: #A3B5C8;
}
.day-detail-hours-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #2895FF;
}

/* Day rest card */
.day-rest-card {
  padding: 80rpx 40rpx;
}
.day-rest-emoji {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}
.day-rest-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A2E4A;
  margin-bottom: 8rpx;
}
.day-rest-sub {
  font-size: 26rpx;
  color: #A3B5C8;
}

/* --- Loading --- */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.6);
  z-index: 100;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E0E0E0;
  border-top-color: #2895FF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
