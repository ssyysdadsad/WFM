/* ===== Schedule Page — 现代磨砂设计 ===== */
.schedule-page {
  padding-bottom: 40rpx;
  background: #F2F5F9;
  min-height: 100vh;
}

/* --- Page Header --- */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px);
}
.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A2233;
  letter-spacing: 1rpx;
}
.export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  border: 2rpx solid rgba(59,139,242,0.3);
  border-radius: 32rpx;
  background: rgba(59,139,242,0.06);
}
.export-icon {
  font-size: 26rpx;
  color: #3B8BF2;
}
.export-text {
  font-size: 24rpx;
  color: #3B8BF2;
  font-weight: 600;
}

/* --- Employee Card --- */
.emp-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.92);
  border-bottom: 1rpx solid rgba(240,245,250,0.6);
  backdrop-filter: blur(10px);
}
.emp-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3B8BF2, #1E6FD9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(30,111,217,0.2);
}
.emp-info {
  display: flex;
  flex-direction: column;
}
.emp-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2233;
}
.emp-dept {
  font-size: 22rpx;
  color: #8899AA;
  margin-top: 4rpx;
}

/* --- Stats Row --- */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(10px);
}
.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
}
.stat-blue {
  background: linear-gradient(145deg, rgba(235,244,255,0.8) 0%, rgba(216,234,255,0.8) 100%);
}
.stat-green {
  background: linear-gradient(145deg, rgba(230,250,240,0.8) 0%, rgba(200,245,223,0.8) 100%);
}
.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.stat-icon-blue {
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(30,111,217,0.2);
}
.stat-icon-green {
  background: linear-gradient(135deg, #34D399, #10B981);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(16,185,129,0.2);
}
.stat-body {
  display: flex;
  flex-direction: column;
}
.stat-label {
  font-size: 22rpx;
  color: #5A7A9A;
  font-weight: 500;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A2233;
  margin-top: 2rpx;
}
.stat-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: #5A7A9A;
  margin-left: 4rpx;
}

/* --- View Tabs --- */
.view-tabs {
  display: flex;
  margin: 16rpx 24rpx 0;
  background: rgba(232,238,244,0.6);
  border-radius: 18rpx;
  padding: 4rpx;
}
.view-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #5A7A9A;
  border-radius: 14rpx;
  transition: all 0.2s;
}
.view-tab.active {
  background: rgba(255,255,255,0.95);
  color: #1A2233;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* --- Search Section --- */
.search-section {
  padding: 16rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.filter-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(232,238,244,0.6);
  color: #5A7A9A;
}
.filter-tag.active {
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(59,139,242,0.2);
}
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(246,248,250,0.8);
  border-radius: 18rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid rgba(232,238,244,0.5);
}
.search-icon {
  font-size: 26rpx;
  opacity: 0.5;
}
.search-input {
  flex: 1;
  font-size: 24rpx;
  color: #1A2233;
}

/* --- Month Bar --- */
.month-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx 12rpx;
  gap: 48rpx;
}
.month-nav {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(232,238,244,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-arrow {
  font-size: 32rpx;
  color: #3B8BF2;
  font-weight: 700;
  line-height: 1;
}
.month-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1A2233;
  letter-spacing: 1rpx;
}

/* --- Calendar Wrap --- */
.calendar-wrap {
  margin: 0 24rpx 16rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 24rpx;
  padding: 16rpx 8rpx 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(10px);
}

/* --- Weekday row --- */
.weekday-row {
  display: flex;
  padding: 8rpx 0 12rpx;
  border-bottom: 1rpx solid rgba(240,245,250,0.6);
}
.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #8899AA;
  font-weight: 500;
}

/* --- Calendar grid --- */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 0;
}
.day-cell {
  width: 14.28%;
  padding: 14rpx 0 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  border-radius: 14rpx;
  box-sizing: border-box;
  position: relative;
}
.day-cell.empty {
  visibility: hidden;
}
.day-cell.selected {
  background: rgba(59,139,242,0.08);
}
.day-cell.today {
  position: relative;
}
.day-cell.today .day-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(30,111,217,0.2);
}
.today-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #3B8BF2;
  margin-top: 2rpx;
}
.day-num {
  font-size: 28rpx;
  color: #1A2233;
  font-weight: 500;
  min-height: 52rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.day-code {
  font-size: 20rpx;
  font-weight: 600;
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
.day-start-time {
  font-size: 16rpx;
  font-weight: 400;
  color: #999;
  text-align: center;
  margin-top: -2rpx;
}

/* --- Detail section --- */
.detail-section {
  padding: 0 24rpx;
}
.detail-date-header {
  margin-bottom: 16rpx;
}
.detail-date-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A2233;
}
.detail-card {
  background: rgba(255,255,255,0.92);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(10px);
}
.detail-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.detail-shift-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.detail-shift-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2233;
}
.detail-shift-time {
  font-size: 24rpx;
  color: #8899AA;
  margin-top: 4rpx;
}
.detail-hours {
  background: rgba(59,139,242,0.08);
  border-radius: 16rpx;
  padding: 10rpx 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #3B8BF2;
  flex-shrink: 0;
}

/* --- Rest card --- */
.rest-card {}
.rest-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0;
}
.rest-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #8899AA;
}
.rest-sub {
  font-size: 24rpx;
  color: #B0BFCC;
}

/* --- Legend --- */
.legend-section {
  padding: 24rpx;
  margin-top: 8rpx;
}
.section-header-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
}
.bar-blue {
  background: linear-gradient(180deg, #3B8BF2, #1E6FD9);
}
.legend-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A2233;
}
.legend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(6px);
}
.legend-color-block {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.legend-code {
  font-size: 22rpx;
  font-weight: 700;
}
.legend-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.legend-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A2233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.legend-time {
  font-size: 20rpx;
  color: #8899AA;
  margin-top: 2rpx;
}
.legend-hours {
  font-size: 22rpx;
  font-weight: 700;
  color: #3B8BF2;
  flex-shrink: 0;
}

/* ========== WEEK VIEW ========== */
.week-nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  gap: 40rpx;
}
.week-row {
  display: flex;
  margin: 0 24rpx 16rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 22rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(10px);
}
.week-day-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 0;
  border-radius: 16rpx;
}
.week-day-cell.today {
  background: rgba(59,139,242,0.08);
}
.week-day-cell.selected {
  background: linear-gradient(135deg, #3B8BF2, #1E6FD9);
  box-shadow: 0 4rpx 12rpx rgba(30,111,217,0.2);
}
.week-day-cell.selected .week-day-label,
.week-day-cell.selected .week-day-num {
  color: #fff;
}
.week-day-label {
  font-size: 22rpx;
  color: #8899AA;
  font-weight: 500;
}
.week-day-num {
  font-size: 30rpx;
  color: #1A2233;
  font-weight: 600;
}
.week-day-code {
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  margin-top: 2rpx;
}
.rest-code {
  color: #9E9E9E;
  background: rgba(245,245,245,0.8);
}

/* Week detail list */
.week-detail-list {
  padding: 0 24rpx;
}
.week-detail-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.92);
  border-radius: 18rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.02);
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(8px);
}
.week-detail-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  flex-shrink: 0;
}
.week-detail-d {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A2233;
}
.week-detail-w {
  font-size: 20rpx;
  color: #8899AA;
}
.week-detail-shift {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 20rpx;
}
.week-detail-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.week-detail-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.week-detail-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A2233;
}
.week-detail-time {
  font-size: 22rpx;
  color: #8899AA;
  margin-top: 2rpx;
}
.week-detail-hours {
  font-size: 26rpx;
  font-weight: 700;
  color: #3B8BF2;
  flex-shrink: 0;
}
.rest-shift {
  flex: 1;
  margin-left: 20rpx;
}
.week-rest-text {
  font-size: 24rpx;
  color: #8899AA;
}

/* ========== DAY VIEW ========== */
.day-nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  gap: 40rpx;
}
.day-detail-wrap {
  padding: 0 24rpx;
}
.day-detail-card {
  background: rgba(255,255,255,0.92);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.6);
  backdrop-filter: blur(20px);
}
.day-detail-badge {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}
.day-detail-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}
.day-detail-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1A2233;
  margin-bottom: 8rpx;
}
.day-detail-time {
  font-size: 26rpx;
  color: #5A7A9A;
  margin-bottom: 24rpx;
}
.day-detail-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: rgba(242,245,249,0.6);
  border-radius: 18rpx;
  padding: 20rpx 48rpx;
  width: 100%;
  box-sizing: border-box;
}
.day-detail-hours-label {
  font-size: 24rpx;
  color: #8899AA;
}
.day-detail-hours-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #3B8BF2;
}

/* Day rest card */
.day-rest-card {
  padding: 80rpx 40rpx;
}
.day-rest-emoji {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}
.day-rest-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A2233;
  margin-bottom: 8rpx;
}
.day-rest-sub {
  font-size: 26rpx;
  color: #8899AA;
}

/* --- Loading --- */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.65);
  z-index: 100;
  backdrop-filter: blur(6px);
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(59,139,242,0.15);
  border-top-color: #3B8BF2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
