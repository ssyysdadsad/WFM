.profile-page { min-height: 100vh; }
.prof-header { position: relative; }
.prof-header-title { display: block; text-align: center; font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 40rpx; position: relative; z-index: 10; }
.prof-avatar { width: 112rpx; height: 112rpx; border-radius: 50%; background: rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center; font-size: 40rpx; border: 4rpx solid rgba(255,255,255,0.3); flex-shrink: 0; }
.prof-name { display: block; font-size: 36rpx; font-weight: 700; color: #fff; }
.prof-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,0.75); margin-top: 4rpx; }
.prof-content { padding: 24rpx; margin-top: -24rpx; }
