{
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2017"],
    "outDir": "./",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "typeRoots": ["./typings"],
    "types": []
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
